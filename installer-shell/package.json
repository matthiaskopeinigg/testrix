{
  "name": "testrix-setup",
  "version": "0.1.0",
  "description": "Testrix Setup",
  "main": "main.js",
  "private": true,
  "author": "Matthias Kopeinigg",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder build --win dir --publish never",
    "pack:win": "electron-builder build --win dir --publish never",
    "pack:linux": "electron-builder build --linux AppImage tar.gz --publish never",
    "pack:mac": "electron-builder build --mac dmg --publish never"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.4.0"
  },
  "build": {
    "appId": "dev.testrix.app.setup",
    "productName": "Testrix Setup",
    "copyright": "Copyright © 2026",
    "icon": "../build/icons/icon.ico",
    "electronFuses": {
      "enableEmbeddedAsarIntegrityValidation": false
    },
    "directories": {
      "output": "../release/setup-shell",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "platforms/**/*",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "asar": true,
    "afterPack": "../scripts/installer-after-pack.cjs",
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}.${ext}",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "tar.gz",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}.${ext}",
      "category": "Development",
      "icon": "../build/icons/icon-1024.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "${productName}.${ext}",
      "icon": "../public/icon.icns",
      "identity": null
    }
  }
}
